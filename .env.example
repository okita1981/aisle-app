# =============================================================
# Aisle - 環境変数設定例
# このファイルを .env にコピーして値を入力してください
# .env はGitにコミットしないこと（.gitignoreに追加済み）
# =============================================================

# ── アクセスパスワード（フロントエンド） ─────────────────────────
# 設定するとアプリ起動時にパスワード認証画面が表示されます。
# 未設定の場合は認証なしで直接アクセスできます（開発時など）。
# Vercelの場合: Settings → Environment Variables に追加してください。
VITE_ACCESS_PASSWORD=your-password-here

# ── AI プロバイダー APIキー（サーバーサイド） ──────────────────
# いずれか1つ以上を設定してください。
# 設定した場合、UIのAPIキー入力欄より優先されます。
# 未設定の場合はUIでユーザーが入力したキーが使用されます。

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI GPT
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
